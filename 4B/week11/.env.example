# ============================================================
# JKYog WhatsApp Bot — Week 6 Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the real .env file.
# ============================================================

# ------------------------------------------------------------
# DATABASE (required — app will not start without this)
# ------------------------------------------------------------
# PostgreSQL connection string. Render Postgres: use the Internal Database URL.
# Accepts both postgres:// and postgresql:// schemes.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# DB connection pool tuning (optional — defaults shown)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300
DB_CONNECT_RETRIES=4
DB_RETRY_BASE_DELAY_SECONDS=1.0

# ------------------------------------------------------------
# TWILIO (required — needed to receive/send WhatsApp messages)
# ------------------------------------------------------------
# Find these in your Twilio console: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# WhatsApp sandbox sender number (keep the whatsapp: prefix)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ------------------------------------------------------------
# GOOGLE AI / GEMINI (required for AI responses)
# Without GOOGLE_API_KEY, bot falls back to keyword matching
# and hardcoded response text.
# ------------------------------------------------------------
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaSy_your_key_here

# Model used for response generation (single-call unified prompt)
GEMINI_MODEL_RESPONSE=gemini-2.5-flash

# Model used for intent classification (only when ENABLE_GEMINI_INTENT=1)
GEMINI_MODEL_INTENT=gemini-2.5-flash-lite

# Set to 1 to enable a separate Gemini call for intent classification.
# Off by default — the unified single-call path handles intent + response together.
ENABLE_GEMINI_INTENT=0

# Set to 1 to disable the unified single-call path and force the legacy
# classify → handler pipeline (useful for debugging).
DISABLE_SINGLE_CALL=0

# ------------------------------------------------------------
# GROK / xAI (optional — alternative LLM provider)
# Set LLM_PROVIDER=grok to switch from Gemini to Grok.
# ------------------------------------------------------------
# Get a key at https://console.x.ai
XAI_API_KEY=xai-your_key_here
XAI_BASE_URL=https://api.x.ai/v1/responses
XAI_MODEL=grok-3-mini
LLM_TIMEOUT_S=15

# Which LLM to use for response generation: gemini (default) or grok
LLM_PROVIDER=gemini

# ------------------------------------------------------------
# GOOGLE MAPS (optional — enables live driving directions)
# Without this, directions fall back to address + GPS instructions.
# ------------------------------------------------------------
# Enable the Maps JavaScript API + Directions API in GCP console.
GOOGLE_MAPS_API_KEY=AIzaSy_your_maps_key_here

# ------------------------------------------------------------
# GOOGLE CALENDAR (optional — enables live event listings)
# Without this, events fall back to knowledge_base/events.json.
# ------------------------------------------------------------
# Paste the full JSON content of a GCP service account key file (single line).
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Calendar ID to pull events from (default: primary)
GOOGLE_CALENDAR_ID=primary

# Alternative: path to a service account JSON file on disk
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ------------------------------------------------------------
# STRIPE (optional — enables payment intents and donation links)
# Without STRIPE_SECRET_KEY, /create-payment returns a config error.
# Donation links fall back to hardcoded test URLs.
# ------------------------------------------------------------
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Pre-configured Stripe Payment Link URLs per temple location.
# If unset, default test URLs are used.
STRIPE_DEFAULT_LINK=https://buy.stripe.com/your_default_link
STRIPE_DALLAS_LINK=https://buy.stripe.com/your_dallas_link
STRIPE_IRVING_LINK=https://buy.stripe.com/your_irving_link
STRIPE_HOUSTON_LINK=https://buy.stripe.com/your_houston_link

# ------------------------------------------------------------
# ESCALATIONS API (required for POST/GET/PUT /escalations/*)
# ------------------------------------------------------------
# Shared secret sent as: Authorization: Bearer <token>
ESCALATIONS_API_TOKEN=change-me-to-a-long-random-secret

# ------------------------------------------------------------
# APP / LOGGING (optional)
# ------------------------------------------------------------
# Team 4A events contract path (public GET routes) is fixed at:
#   /api/v2/events
# Keep client calls aligned to:
#   {BASE_URL}/api/v2/events
LOG_LEVEL=INFO

# ------------------------------------------------------------
# STRESS TEST SCRIPTS (local execution only — not used by the app)
# Set these in your shell before running stress_test_*.py scripts.
# ------------------------------------------------------------
STRESS_TEST_URL=https://your-service.onrender.com/health/db
STRESS_TEST_TIMEOUT=10
STRESS_TEST_WARMUP=5
STRESS_TEST_BURST_REQUESTS=50
STRESS_TEST_CONCURRENCY=10
STRESS_TEST_SUSTAINED_ROUNDS=3
STRESS_TEST_SUSTAINED_DELAY=2
STRESS_TEST_IDLE_SECONDS=30
STRESS_TEST_POST_IDLE_REQUESTS=5
STRESS_TEST_RAPID_BURST=20
STRESS_TEST_ESCALATION_PROBE=10

# stress_test_escalations.py knobs
ESCALATION_SERIAL_CREATES=20
ESCALATION_CONCURRENT_CREATES=50
ESCALATION_CONCURRENCY=10
ESCALATION_STATUS_TRANSITIONS=30
